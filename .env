# ================= CONFIGURACIÓN DEL SERVIDOR =================
PORT=3000
NODE_ENV=development

# ================= BASE DE DATOS =================
# Ruta del archivo SQLite — se crea automáticamente si no existe
DB_PATH=./data/radar.db

# ================= RECOLECCIÓN DE NOTICIAS =================
# Intervalo del cron en minutos (recomendado: 30)
CRON_INTERVALO_MINUTOS=30
# Días máximos que se conservan las noticias antes de limpiarse
DIAS_RETENCION=90

# ================= SEGURIDAD =================
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000
